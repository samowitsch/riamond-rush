{
  "devDependencies": {
    "esbuild": "^0.27.4"
  },
  "scripts": {
    "concat": "cat ./js/**/*.js > ./dist/riamond.all.js",
    "buildjs": "./node_modules/.bin/esbuild ./dist/riamond.all.js --bundle --minify --sourcemap --target=chrome58,firefox57,safari11,edge16 --outfile=./dist/riamond.all.min.js"
  },
  "watch": {
    "riamond": "{js}/**/*.js"
  }
}
